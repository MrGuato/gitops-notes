---
import "../styles/global.css";
const { title = "GitOps Notes", description = "Building. Breaking. Fixing. Securing. Learning — one post at a time." } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="MrGuato's GitOps Notes" />
  </head>

  <body>
    <div class="nav">
      <div class="nav-inner">
        <div class="brand"><a href={`${base}/`}>MrGuato's GitOps Notes</a></div>
        <div>
          <a href={`${base}/writing`}>Writing</a>
          <a href={`${base}/about`}>About</a>
        </div>
      </div>
    </div>

    <main class="container">
      <slot />
      <footer class="footer">Built on GitHub Pages &mdash; Built by Jonathan with love ❤️. If it's not committed, it doesn't exist.</footer>
    </main>
  </body>
</html>
